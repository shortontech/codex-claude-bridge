PORT=8083
# ChatGPT Codex auth.json path (must contain tokens.access_token).
CODEX_AUTH_JSON=~/.codex/auth.json
# Optional override for upstream base URL.
OPENAI_BASE_URL=
# Optional override for upstream responses path (default: /responses).
OPENAI_RESPONSES_PATH=
# Used when request `system` is empty.
DEFAULT_INSTRUCTIONS=You are a helpful assistant.
DEFAULT_CODEX_MODEL=gpt-5.3-codex
# Any inbound Claude "haiku" model maps here.
HAIKU_MODEL=gpt-5.3-codex
PROXY_API_KEY=
DEBUG_JSON=false
# 0 means no truncation. Set >0 to cap debug payload length.
DEBUG_JSON_MAX_LEN=0
# Optional: append structured debug entries to this JSONL file.
DEBUG_JSONL_PATH=
